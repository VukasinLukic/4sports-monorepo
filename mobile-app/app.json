{
  "expo": {
    "name": "4sports",
    "slug": "app-4sports",
    "version": "1.0.1",
    "scheme": "foursports",
    "orientation": "portrait",
    "icon": "./assets/mobile_icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "owner": "org-4sports",
    "description": "Sports club management app for coaches and parents. Manage attendance, payments, medical checks, events and more.",
    "splash": {
      "image": "./assets/mobile_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.foursports.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow 4Sports to access your camera for QR code scanning.",
        "NSPhotoLibraryUsageDescription": "Allow 4Sports to access your photo library to upload profile pictures and media.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.foursports.mobile",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/mobile_icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow 4Sports to access your camera for QR code scanning."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/mobile_icon.png",
          "color": "#4caf50"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow 4Sports to access your photo library to upload profile pictures and media."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "41c3dc4d-4720-4c36-bb5e-6196025f89a5"
      }
    }
  }
}
