# 4SPORTS MOBILE APP - ENVIRONMENT VARIABLES
# NIKAD NE COMMIT-UJ PRAVI .env FAJL NA GIT!

# Backend API
EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1

# Firebase Configuration (Mobile App)
# Get these values from Firebase Console -> Project Settings -> Your Apps
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=project4sports
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=project4sports.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456:android:abcdef
